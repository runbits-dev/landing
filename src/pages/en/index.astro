---
import Layout from '../../layouts/Layout.astro';
import PricingCard from '../../components/PricingCard.astro';
import SavingsCalculator from '../../components/SavingsCalculator';
import { t } from '../../i18n';
const locale = 'en';
const tr = t(locale);
const plans = [
  { key: 'starter', price: 49 },
  { key: 'growth',  price: 129, popular: true },
  { key: 'pro',     price: 299 },
  { key: 'fleet',   price: 199, isFleet: true },
];
---
<Layout title="Runbits — Your delivery, your rules" locale={locale}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-50 via-white to-white"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-24 md:py-36 text-center">
      <span class="inline-block bg-brand-100 text-brand-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-6">{tr.hero.badge}</span>
      <h1 class="text-5xl md:text-7xl font-black text-gray-900 leading-tight mb-6">
        {tr.hero.title}<br /><span class="text-brand-600">{tr.hero.titleHighlight}</span>
      </h1>
      <p class="text-xl text-gray-500 max-w-2xl mx-auto mb-10">{tr.hero.subtitle}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://app.runbits.io/register" class="bg-brand-600 text-white font-bold px-8 py-4 rounded-xl text-lg hover:bg-brand-700 transition-colors shadow-lg shadow-brand-200">{tr.hero.cta}</a>
        <a href="#calculator" class="bg-white text-gray-700 font-semibold px-8 py-4 rounded-xl text-lg border border-gray-200 hover:border-gray-300 transition-colors">{tr.hero.ctaSecondary}</a>
      </div>
      <p class="text-sm text-gray-400 mt-4">{tr.hero.noCreditCard}</p>
    </div>
  </section>
  <section id="calculator" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12"><h2 class="text-4xl font-black text-gray-900 mb-4">{tr.savings.title}</h2><p class="text-lg text-gray-500 max-w-xl mx-auto">{tr.savings.subtitle}</p></div>
      <SavingsCalculator tr={tr.savings} client:load />
    </div>
  </section>
  <section id="pricing" class="py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16"><h2 class="text-4xl font-black text-gray-900 mb-4">{tr.pricing.title}</h2><p class="text-lg text-gray-500">{tr.pricing.subtitle}</p></div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-start">
        {plans.map(plan => { const pd = tr.pricing.plans[plan.key as keyof typeof tr.pricing.plans]; return <PricingCard name={pd.name} price={plan.price} description={pd.description} volume={pd.volume} features={pd.features} popular={plan.popular} isFleet={plan.isFleet} cta={tr.pricing.cta} trialNote={tr.pricing.trialNote} perMonth={tr.pricing.perMonth} />; })}
      </div>
      <p class="text-center text-sm text-gray-400 mt-8">Volume over $80,000 USD/month? <a href="mailto:hola@runbits.io" class="text-brand-600 font-medium hover:underline">Let's talk</a></p>
    </div>
  </section>
  <section class="py-24 bg-white"><div class="max-w-3xl mx-auto px-4"><h2 class="text-4xl font-black text-gray-900 mb-12 text-center">{tr.faq.title}</h2><div class="space-y-6">{tr.faq.items.map(item => (<div class="border border-gray-200 rounded-xl p-6"><h3 class="font-bold text-gray-900 mb-2">{item.q}</h3><p class="text-gray-500 text-sm leading-relaxed">{item.a}</p></div>))}</div></div></section>
  <section class="py-24 bg-brand-600"><div class="max-w-3xl mx-auto px-4 text-center text-white"><h2 class="text-4xl font-black mb-4">Start today, free.</h2><p class="text-xl opacity-80 mb-10">14 days free. No card. No lock-in.</p><a href="https://app.runbits.io/register" class="inline-block bg-white text-brand-700 font-bold px-10 py-4 rounded-xl text-lg hover:bg-brand-50 transition-colors shadow-xl">{tr.hero.cta}</a></div></section>
</Layout>
